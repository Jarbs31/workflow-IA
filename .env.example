# Copie este arquivo para .env e preencha com os valores do seu projeto Supabase
# cp .env.example .env

# URL do projeto (Dashboard → Settings → API → Project URL)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave publishable (Dashboard → Settings → API → Publishable key)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_sua_chave_aqui

# Chave anon legada (Dashboard → Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# Referência do projeto (Dashboard → Settings → General → Reference ID)
SUPABASE_PROJECT_REF=seu_project_ref

# Ambiente: development | staging | production
VITE_APP_ENV=development
